/* q1 */
SELECT to_timestamp(0) as DEFAULT_TIMESTAMP, to_timestamp(4294967295) AS MAX_TIMESTAMP;
/* q2 */
SELECT make_interval(secs => 0) as DEFAULT_INTERVAL,
make_interval(years => 136, months => 1, days => 6, hours=>6, mins => 28, secs => 15) AS MAX_INTERVAL1,
make_interval(secs => 4294967295) AS MAX_INTERVAL2;
